    "image-size": "^2.0.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "probe-image-size": "^7.3.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "vite-plugin-compression": "^0.5.1"
  },
